<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.platform.mapper.CartMapper">

    <select id="list" resultType="com.project.platform.entity.Cart">
        SELECT * FROM `cart`
        <where>
            <if test="userId != null">
                AND user_id = #{userId}
            </if>
            <if test="skuId != null and skuId != ''">
                AND sku_id = #{skuId}
            </if>
        </where>
        ORDER BY id DESC
    </select>
    <select id="selectByUserIdAndSelected" resultType="com.project.platform.entity.Cart">
    SELECT * FROM cart
    WHERE user_id = #{userId} AND selected = 1
    </select>

    <insert id="insert" parameterType="com.project.platform.entity.Cart" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO `cart`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="skuId != null">sku_id,</if>
            <if test="goodsId != null">goods_id,</if>
            <if test="name != null">name,</if>
            <if test="picture != null">picture,</if>
            <if test="count != null">count,</if>
            <if test="price != null">price,</if>
            <if test="nowPrice != null">now_price,</if>
            <if test="stock != null">stock,</if>
            <if test="selected != null">selected,</if>
            <if test="attrsText != null">attrs_text,</if>
            <if test="isEffective != null">is_effective,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        VALUES
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="skuId != null">#{skuId},</if>
            <if test="goodsId != null">#{goodsId},</if>
            <if test="name != null">#{name},</if>
            <if test="picture != null">#{picture},</if>
            <if test="count != null">#{count},</if>
            <if test="price != null">#{price},</if>
            <if test="nowPrice != null">#{nowPrice},</if>
            <if test="stock != null">#{stock},</if>
            <if test="selected != null">#{selected},</if>
            <if test="attrsText != null">#{attrsText},</if>
            <if test="isEffective != null">#{isEffective},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="updateById" parameterType="com.project.platform.entity.Cart">
        UPDATE `cart`
        <set>
            <if test="userId != null">
                user_id = #{userId},
            </if>
            <if test="skuId != null">
                sku_id = #{skuId},
            </if>
            <if test="goodsId != null">
                goods_id = #{goodsId},
            </if>
            <if test="name != null">
                name = #{name},
            </if>
            <if test="picture != null">
                picture = #{picture},
            </if>
            <if test="count != null">
                count = #{count},
            </if>
            <if test="price != null">
                price = #{price},
            </if>
            <if test="nowPrice != null">
                now_price = #{nowPrice},
            </if>
            <if test="stock != null">
                stock = #{stock},
            </if>
            <if test="selected != null">
                selected = #{selected},
            </if>
            <if test="attrsText != null">
                attrs_text = #{attrsText},
            </if>
            <if test="isEffective != null">
                is_effective = #{isEffective},
            </if>
            <if test="createTime != null">
                create_time = #{createTime},
            </if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="removeByIds">
        DELETE FROM `cart`
        WHERE id IN
        <foreach item="id" collection="list" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>