<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.platform.mapper.GoodsSkuMapper">
    <update id="updateStock" parameterType="com.project.platform.entity.GoodsSku">
        update goods_sku
        set stock = #{stock}
        where id = #{id}
    </update>
    <select id="listByGoodsId" resultType="com.project.platform.entity.GoodsSku">
        SELECT * FROM goods_sku WHERE goods_id = #{goodsId}
    </select>
    <delete id="deleteByGoodsId">
        DELETE FROM goods_sku WHERE goods_id = #{goodsId}
    </delete>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO goods_sku (goods_id, sku_name_arr, image, price, discount_price, stock)
        VALUES (#{goodsId}, #{skuNameArr}, #{image}, #{price}, #{discountPrice}, #{stock})
    </insert>
    <select id="selectById" resultType="com.project.platform.entity.GoodsSku">
        select * from goods_sku where id = #{id}
    </select>
</mapper>