<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.platform.mapper.GoodsSpecItemMapper">
    <select id="listBySpecId" resultType="com.project.platform.entity.GoodsSpecItem">
        SELECT * FROM goods_spec_item WHERE spec_id = #{specId}
    </select>
    <delete id="deleteByGoodsId">
        DELETE goods_spec_item
    FROM goods_spec_item
    JOIN goods_spec ON goods_spec_item.spec_id = goods_spec.id
    WHERE goods_spec.goods_id = #{goodsId}
    </delete>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO goods_spec_item (spec_id, name)
        VALUES (#{specId}, #{name})
    </insert>
</mapper>