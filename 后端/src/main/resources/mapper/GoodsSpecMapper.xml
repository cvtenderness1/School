<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.platform.mapper.GoodsSpecMapper">
    <select id="listByGoodsId" resultType="com.project.platform.entity.GoodsSpec">
        SELECT * FROM goods_spec WHERE goods_id = #{goodsId}
    </select>
    <delete id="deleteByGoodsId">
        DELETE FROM goods_spec WHERE goods_id = #{goodsId}
    </delete>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO goods_spec (goods_id, name)
        VALUES (#{goodsId}, #{name})
    </insert>

</mapper>